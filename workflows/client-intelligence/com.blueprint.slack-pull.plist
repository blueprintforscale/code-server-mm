        <integer>15</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>/Users/bp/projects/workflows/client-intelligence/launchd-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/bp/projects/workflows/client-intelligence/launchd-stderr.log</string>
    <key>WorkingDirectory</key>
    <string>/Users/bp/projects/workflows/client-intelligence</string>
</dict>
</plist>
